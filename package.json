{
  "name": "codex-worker",
  "displayName": "codex-worker",
  "description": "codex-worker is a Codex Editor (VS Code–compatible) extension that lets users define, submit, and monitor GPU-intensive background jobs—starting with TTS training and inference—by generating a versioned YAML manifest inside the project. It scans raw Codex project files to build datasets, performs preflight validation, manages GitLab project sharing with GPU workers, and tracks job state purely through repository artifacts, enabling reliable, resumable processing without tight coupling to worker infrastructure.",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JEdward7777/codex_worker_frontend.git"
  },
  "engines": {
    "vscode": "^1.77.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gpu-jobs",
          "title": "GPU Jobs",
          "icon": "$(server-process)"
        }
      ]
    },
    "views": {
      "gpu-jobs": [
        {
          "id": "codex-worker-jobs",
          "name": "Jobs"
        }
      ]
    },
    "commands": [
      {
        "command": "codex-worker.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "codex-worker.testGitLabConnection",
        "title": "GPU Jobs: Test GitLab Connection"
      },
      {
        "command": "codex-worker.testManifestGeneration",
        "title": "GPU Jobs: Test Manifest Generation"
      },
      {
        "command": "codex-worker.testAudioDiscovery",
        "title": "GPU Jobs: Test Audio Discovery"
      },
      {
        "command": "codex-worker.refreshJobs",
        "title": "Refresh Jobs",
        "icon": "$(refresh)"
      },
      {
        "command": "codex-worker.newJob",
        "title": "New Job",
        "icon": "$(add)"
      },
      {
        "command": "codex-worker.cancelJob",
        "title": "Cancel Job",
        "icon": "$(close)"
      },
      {
        "command": "codex-worker.viewJobDetail",
        "title": "View Job Details",
        "icon": "$(info)"
      },
      {
        "command": "codex-worker.viewPrivacyPolicy",
        "title": "GPU Jobs: View Privacy Policy",
        "icon": "$(shield)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codex-worker.refreshJobs",
          "when": "view == codex-worker-jobs",
          "group": "navigation"
        },
        {
          "command": "codex-worker.newJob",
          "when": "view == codex-worker-jobs",
          "group": "navigation"
        },
        {
          "command": "codex-worker.viewPrivacyPolicy",
          "when": "view == codex-worker-jobs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "codex-worker.cancelJob",
          "when": "view == codex-worker-jobs && viewItem =~ /cancelable/",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Codex Worker",
      "properties": {
        "codex-worker.workerUserId": {
          "type": "number",
          "default": 551,
          "description": "GitLab user ID of the GPU worker (default: 551)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.77.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
